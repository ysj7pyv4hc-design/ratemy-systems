# Rate My Systems — production environment (set these in App Runner, never commit a real .env)

# REQUIRED
DATABASE_URL=postgresql://rms:CHANGE_ME@your-rds-endpoint:5432/ratemy
RMS_ENV=prod
BASE_URL=https://ratemy.systems

# REQUIRED secrets — generate each with:  openssl rand -hex 32
RMS_PEPPER=CHANGE_ME_64_HEX          # HMAC pepper for email/IP hashing. LOSING THIS ORPHANS IDENTITIES; ROTATING IT INVALIDATES DEDUPE. Back it up.
ADMIN_TOKEN=CHANGE_ME_64_HEX         # moderation + config publish + manual jobs
JOB_TOKEN=CHANGE_ME_64_HEX           # EventBridge weekly publication trigger

# EMAIL (optional at launch — without it, the site runs fully anonymous;
# magic-link sign-in activates the moment these are set)
MAIL_PROVIDER=smtp                   # console | smtp   (smtp works with AWS SES SMTP creds)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
MAIL_FROM=signin@ratemy.systems

PORT=8080
